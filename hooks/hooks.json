    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "name": "babysitter-session-end",
            "type": "command",
            "command": "npx -y -p @a5c-ai/hooks-mux-cli -c \"a5c-hooks-mux invoke --adapter gemini --handler 'bash ${GEMINI_EXTENSION_PATH}/hooks/babysitter-proxied-session-end.sh' --json\"",
